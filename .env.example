# Copy this file to .env.local and fill in your values

# YOUR PLATFORM WALLET ADDRESS
# This is the wallet that receives user deposits.
# One EVM address works across all chains (Ethereum, BSC, Polygon, Arbitrum, etc.)
NEXT_PUBLIC_PLATFORM_WALLET=0xYourWalletAddressHere
